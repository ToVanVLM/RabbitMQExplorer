@page
@model IndexModel
@using RabbitMQExplorer.Web.Models
@{
    ViewData["Title"] = "RabbitMQ Explorer";
    Layout = "_Layout";
    var appContextConnectionsJson = System.Text.Json.JsonSerializer.Serialize(
        Model.Connections.Select(c => new { id = c.Id, name = c.Name, host = c.Host, port = c.Port, environment = c.Environment, defaultVHost = c.DefaultVHost, isReadOnly = c.IsReadOnly })
    );
}

<div class="app-shell" id="appShell">

    <!-- ── SIDEBAR ────────────────────────────────────────── -->
    <aside class="sidebar" id="sidebar" aria-label="Sidebar">

        <!-- Zoekbalk -->
        <div class="sidebar__search">
            <div class="search-input search-input--sidebar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                <input type="text" id="sidebarSearch" placeholder="Zoek queue..." autocomplete="off" />
                <button id="sidebarSearchClear" class="btn btn--icon" style="display:none" title="Wis zoekopdracht" aria-label="Wis zoekopdracht">✕</button>
            </div>
        </div>

        <!-- Favorieten sectie -->
        <div class="sidebar__section" id="sectionFavorites">
            <div class="sidebar__section-header" onclick="SidebarExtras.toggleSection('favorites')">
                <svg viewBox="0 0 24 24" fill="currentColor" stroke="none" width="13" height="13" style="color:var(--fg-warning)">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
                <span class="flex-1">Favorieten</span>
                <span class="sidebar__section-count" id="favoritesCount"></span>
                <svg class="sidebar__chevron" id="chevronFavorites" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12"><polyline points="6 9 12 15 18 9"/></svg>
            </div>
            <ul class="tree" id="favoritesList"></ul>
        </div>

        <!-- Recent sectie -->
        <div class="sidebar__section" id="sectionRecent">
            <div class="sidebar__section-header" onclick="SidebarExtras.toggleSection('recent')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="13" height="13">
                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
                <span class="flex-1">Recent</span>
                <svg class="sidebar__chevron" id="chevronRecent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12"><polyline points="6 9 12 15 18 9"/></svg>
            </div>
            <ul class="tree" id="recentList"></ul>
        </div>

        <!-- Verbindingen panel -->
        <div id="panel-connections" class="sidebar__panel">
            <div class="sidebar__header">
                Verbindingen
                <button class="btn btn--icon" onclick="showThresholdSettings()" title="Drempelwaarden instellen" aria-label="Drempelwaarden">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="13" height="13">
                        <line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="20" y2="12"/><line x1="12" y1="18" x2="20" y2="18"/>
                        <circle cx="4" cy="6" r="2" fill="currentColor"/><circle cx="4" cy="12" r="2" fill="none"/><circle cx="8" cy="12" r="2" fill="currentColor"/><circle cx="8" cy="18" r="2" fill="none"/><circle cx="12" cy="18" r="2" fill="currentColor"/>
                    </svg>
                </button>
                <a id="btnConnectionsSettings" href="/Connections" class="btn btn--icon" title="Connecties beheren" aria-label="Connecties beheren">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="14" height="14">
                        <circle cx="12" cy="12" r="3"></circle>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06A1.65 1.65 0 0 0 15 19.4a1.65 1.65 0 0 0-1 .6 1.65 1.65 0 0 0-.33 1V21a2 2 0 1 1-4 0v-.09a1.65 1.65 0 0 0-.33-1 1.65 1.65 0 0 0-1-.6 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.6 15a1.65 1.65 0 0 0-.6-1 1.65 1.65 0 0 0-1-.33H3a2 2 0 1 1 0-4h.09a1.65 1.65 0 0 0 1-.33 1.65 1.65 0 0 0 .6-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.6a1.65 1.65 0 0 0 1-.6 1.65 1.65 0 0 0 .33-1V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 .33 1 1.65 1.65 0 0 0 1 .6 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9c.24.32.45.68.6 1 .11.33.17.67.17 1s-.06.67-.17 1c-.15.32-.36.68-.6 1z"></path>
                    </svg>
                </a>
            </div>
            <div class="sidebar__content">
                <ul class="tree" id="connectionTree">
                    @foreach (var conn in Model.Connections)
                    {
                        <li>
                            <div class="tree-item tree-item--connection"
                                 data-connection-id="@conn.Id"
                                 data-connection-name="@conn.Name"
                                 onclick="toggleConnection(@conn.Id, this)"
                                 draggable="false">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16">
                                    <circle cx="12" cy="12" r="10"/>
                                    <line x1="2" y1="12" x2="22" y2="12"/>
                                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                                </svg>
                                <span class="truncate flex-1">@conn.Name</span>
                                @if (conn.IsReadOnly)
                                {
                                    <svg class="icon-readonly" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12" title="Read-only"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                }
                                <span class="env-badge @conn.Environment.ToLower()">@conn.Environment</span>
                                <span class="conn-refresh-ts" id="refreshed-@conn.Id" title="Nog niet bijgewerkt"></span>
                            </div>
                            <ul class="tree" id="vhosts-@conn.Id" style="display:none"></ul>
                        </li>
                    }
                </ul>
                @if (!Model.Connections.Any())
                {
                    <div class="empty-state" style="height:200px">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="12" cy="12" r="10"/></svg>
                        <h3>Geen verbindingen</h3>
                        <p><a href="/Connections/Create">Voeg een verbinding toe</a> om te beginnen.</p>
                    </div>
                }
            </div>
        </div>

    </aside>

    <div class="splitter splitter--vertical" id="sidebarSplitter" role="separator" aria-label="Sidebar breedte aanpassen" aria-orientation="vertical" tabindex="0"></div>

    <!-- ── EDITOR AREA ────────────────────────────────────── -->
    <div class="editor-area" id="editorArea">

        <!-- Tab bar -->
        <div class="tab-bar" id="tabBar" role="tablist" aria-label="Open queues"></div>

        <!-- Toolbar -->
        <div class="toolbar" id="mainToolbar" style="display:none">
            <div class="search-input">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                <input type="text" id="msgSearch" placeholder="Zoeken in berichten..." autocomplete="off" />
                <button class="search-input__clear" id="msgSearchClear" onclick="clearSearch()" style="display:none" title="Zoekopdracht wissen">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="10" height="10">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>
            <button class="btn btn--ghost btn--sm" onclick="showFilterBuilder()" title="Veldfilter toevoegen">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12">
                    <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
                </svg>
                Filter
            </button>
            <div class="toolbar__separator"></div>
            <button class="btn" id="btnFetch" onclick="fetchMessages()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13">
                    <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.66"/>
                </svg>
                Ophalen
            </button>
            <input type="number" id="fetchCount" value="100" min="1" max="50000" class="form-control" style="width:80px" title="Aantal berichten" />
            <div class="toolbar__separator"></div>
            <button class="btn btn--ghost" id="btnCopy" onclick="copySelected()" disabled title="Kopieer geselecteerde berichten">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13">
                    <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                </svg>
                Kopieer
            </button>
            <button class="btn btn--ghost" id="btnMove" onclick="moveSelected()" disabled title="Verplaats geselecteerde berichten">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13">
                    <polyline points="5 9 2 12 5 15"/><polyline points="19 9 22 12 19 15"/>
                    <line x1="2" y1="12" x2="22" y2="12"/>
                </svg>
                Verplaats
            </button>
            <button class="btn btn--danger" id="btnPurge" onclick="purgeQueue()" disabled title="Maak de volledige queue leeg (purge)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13">
                    <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/>
                    <path d="M10 11v6"/><path d="M14 11v6"/>
                </svg>
                Purge queue
            </button>
            <div class="toolbar__separator"></div>
            <button class="btn btn--ghost" onclick="saveMessages()" title="Exporteer naar bestand">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                    <polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                Exporteer
            </button>
            <label class="btn btn--ghost" title="Importeer berichten uit bestand" style="cursor:pointer">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                    <polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
                </svg>
                Importeer
                <input type="file" accept=".json" style="display:none" onchange="importMessages(this)" />
            </label>
            <div class="ms-auto d-flex gap-1">
                <label class="text-muted" style="font-size:11px;align-self:center">Auto-refresh:</label>
                <select class="form-control" id="refreshInterval" onchange="setRefreshInterval(this.value)" style="width:90px">
                    <option value="0">Uit</option>
                    <option value="5">5s</option>
                    <option value="10">10s</option>
                    <option value="30">30s</option>
                    <option value="60">1min</option>
                </select>
                <span id="selectionCount" class="text-muted" style="font-size:11px;align-self:center;min-width:80px"></span>
            </div>
        </div>

        <!-- Filter bar (actieve chips) -->
        <div class="filter-bar" id="filterBar" style="display:none">
            <div class="filter-chips" id="filterChips"></div>
            <button class="btn btn--ghost btn--sm" id="btnClearFilters" onclick="clearAllFilters()" style="display:none" title="Alle filters wissen">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="11" height="11">
                    <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
                </svg>
                Alles wissen
            </button>
        </div>

        <!-- Filter builder (veldspecifiek filter toevoegen) -->
        <div class="filter-builder" id="filterBuilder" style="display:none">
            <span class="filter-builder__label">Filter op:</span>
            <select class="form-control" id="fbField" style="width:auto">
                <option value="any">Alle velden</option>
                <option value="body">Body</option>
                <option value="routing_key">Routing Key</option>
                <option value="exchange">Exchange</option>
                <option value="content_type">Content-Type</option>
                <option value="message_id">Message-ID</option>
                <option value="correlation_id">Correlation-ID</option>
                <option value="header_key">Header sleutel</option>
                <option value="header_value">Header waarde</option>
            </select>
            <input type="text" class="form-control" id="fbValue" placeholder="Zoekwaarde…" style="flex:1;min-width:120px;max-width:260px" autocomplete="off" />
            <button class="btn btn--sm" onclick="addFilterFromBuilder()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="11" height="11">
                    <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
                Toevoegen
            </button>
            <button class="btn btn--ghost btn--sm" onclick="hideFilterBuilder()">✕</button>
        </div>

        <!-- Editor content -->
        <div class="editor-content" id="editorContent">
            <div class="empty-state" id="welcomeState">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                    <rect x="4" y="4" width="16" height="16" rx="2"/>
                    <line x1="8" y1="12" x2="16" y2="12"/>
                    <line x1="12" y1="8" x2="12" y2="16"/>
                </svg>
                <h3>Geen queue geselecteerd</h3>
                <p>Selecteer een verbinding in de sidebar en klik op een queue om berichten te bekijken.</p>
            </div>

            <!-- Message grid container -->
            <div id="msgGridWrap" style="display:none;height:100%;flex-direction:column">
                <div class="msg-table-wrap" id="msgTableWrap">
                    <table class="msg-table" id="msgTable">
                        <thead>
                            <tr>
                                <th style="width:36px">
                                    <input type="checkbox" id="selectAll" onchange="toggleSelectAll(this)" aria-label="Alles selecteren" />
                                </th>
                                <th data-col="index" onclick="sortBy('index')"># <span class="sort-icon">↕</span></th>
                                <th data-col="routing_key" onclick="sortBy('routing_key')">Routing Key <span class="sort-icon">↕</span></th>
                                <th data-col="exchange" onclick="sortBy('exchange')">Exchange <span class="sort-icon">↕</span></th>
                                <th data-col="content_type" onclick="sortBy('content_type')">Content-Type <span class="sort-icon">↕</span></th>
                                <th data-col="payload_bytes" onclick="sortBy('payload_bytes')">Grootte <span class="sort-icon">↕</span></th>
                                <th data-col="timestamp" onclick="sortBy('timestamp')">Timestamp <span class="sort-icon">↕</span></th>
                                <th data-col="message_id" onclick="sortBy('message_id')">Message-ID <span class="sort-icon">↕</span></th>
                                <th data-col="correlation_id" onclick="sortBy('correlation_id')">Correlation-ID <span class="sort-icon">↕</span></th>
                                <!-- Dynamische extractiekolommen worden hier door JS ingevoegd -->
                            </tr>
                        </thead>
                        <tbody id="msgTbody"></tbody>
                    </table>
                </div>

                <div class="splitter splitter--horizontal" id="detailSplitter" style="display:none" role="separator" aria-label="Berichtdetail hoogte aanpassen" aria-orientation="horizontal" tabindex="0"></div>

                <!-- Detail panel (bottom split) -->
                <div class="detail-panel" id="detailPanel" style="display:none">
                    <div class="detail-panel__tabs">
                        <div class="detail-panel__tab active" onclick="showDetailTab('body', this)">Body</div>
                        <div class="detail-panel__tab" onclick="showDetailTab('properties', this)">Properties</div>
                        <div class="detail-panel__tab" onclick="showDetailTab('headers', this)">Headers</div>
                        <div class="detail-panel__tab" onclick="showDetailTab('dlq', this)">DLQ / Death History</div>
                        <!-- Pretty / Raw toggle (alleen zichtbaar bij body-tab) -->
                        <div class="body-mode-toggle" id="bodyModeToggle">
                            <button class="mode-btn active" id="btnPretty" onclick="setBodyMode('pretty')">Pretty</button>
                            <button class="mode-btn" id="btnRaw" onclick="setBodyMode('raw')">Raw</button>
                        </div>
                        <!-- Ongeldige payload indicator -->
                        <span class="body-invalid-badge" id="bodyInvalidIndicator" style="display:none">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                            Ongeldige JSON
                        </span>
                        <div class="ms-auto d-flex gap-1" style="padding:4px 8px">
                            <button class="btn btn--ghost btn--sm" id="btnCopySection" onclick="copyCurrentSection()" title="Inhoud kopiëren">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12">
                                    <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                                </svg>
                                Kopieer
                            </button>
                            <button class="btn" onclick="editAndRepublish()" id="btnRepublish" style="display:none">
                                Opnieuw versturen
                            </button>
                            <button class="btn btn--ghost" onclick="closeDetailPanel()">✕</button>
                        </div>
                    </div>
                    <div class="detail-panel__content" id="detailContent">
                        <div id="tab-body" class="monaco-container" style="height:100%"></div>
                        <div id="tab-properties" class="props-grid" style="display:none"></div>
                        <div id="tab-headers" class="props-grid" style="display:none"></div>
                        <div id="tab-dlq" style="display:none;padding:12px;font-family:var(--font-mono);font-size:12px;overflow:auto;height:100%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── STATUS BAR ─────────────────────────────────────── -->
    <div class="status-bar" id="statusBar">
        <span class="status-bar__item" id="statusConnection">Geen verbinding</span>
        <span class="status-bar__sep">|</span>
        <span class="status-bar__item" id="statusQueue"></span>
        <span class="status-bar__sep" id="statusQueueSep" style="display:none">|</span>
        <span class="status-bar__item" id="statusMessages"></span>
        <span class="status-bar__item status-bar__readonly" id="statusReadOnly" style="display:none">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="11" height="11"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            READ-ONLY
        </span>
        <div class="status-bar--right">
            <span id="statusRefresh" class="status-bar__item"></span>
            <span class="status-bar__item" id="statusFilter"></span>
            <button id="themeToggle" class="status-bar__theme-btn" title="Thema wisselen" aria-label="Thema wisselen">
                <svg id="themeIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="12" height="12">
                    <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/>
                    <line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/>
                    <line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                </svg>
            </button>
        </div>
    </div>
</div>

<!-- ── MODALS (via JS gegenereerd) ──────────────────────── -->
<div id="modalContainer"></div>

@section Scripts {
<script>
    // Initialiseer app context vanuit server
    window.AppContext = {
        connections: @Html.Raw(appContextConnectionsJson),
        queueHubUrl: '/hubs/queue'
    };
</script>
<script src="~/js/signalr-client.js" asp-append-version="true"></script>
<script src="~/js/activity-bar.js" asp-append-version="true"></script>
<script src="~/js/sidebar.js" asp-append-version="true"></script>
<script src="~/js/sidebar-extras.js" asp-append-version="true"></script>
<script src="~/js/tabs.js" asp-append-version="true"></script>
<script src="~/js/messages.js" asp-append-version="true"></script>
<script src="~/js/drag-drop.js" asp-append-version="true"></script>
<script src="~/js/editor.js" asp-append-version="true"></script>
<script src="~/js/extraction.js" asp-append-version="true"></script>
<script src="~/js/alerts.js" asp-append-version="true"></script>
<script src="~/js/sparkline.js" asp-append-version="true"></script>
<script src="~/js/split-panels.js" asp-append-version="true"></script>
}
