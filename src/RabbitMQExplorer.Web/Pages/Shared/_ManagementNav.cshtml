@{
    var path = ViewContext.HttpContext.Request.Path.ToString().ToLower();
}
<nav class="mgmt-nav">
    <a href="/" class="mgmt-nav__brand" title="Terug naar werkruimte">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18">
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
        </svg>
        RabbitMQ Explorer
    </a>
    <div class="mgmt-nav__sep"></div>
    <div class="mgmt-nav__links">
        <a href="/Dashboard"
           class="mgmt-nav__link @(path.StartsWith("/dashboard") ? "active" : "")">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="13" height="13"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
            Dashboard
        </a>
        <a href="/Connections"
           class="mgmt-nav__link @(path.StartsWith("/connections") ? "active" : "")">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="13" height="13"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            Verbindingen
        </a>
        <a href="/ExtractionRules"
           class="mgmt-nav__link @(path.StartsWith("/extractionrules") ? "active" : "")">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="13" height="13"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/></svg>
            Extractieregels
        </a>
        <a href="/Messages/Backup"
           class="mgmt-nav__link @(path.StartsWith("/messages") ? "active" : "")">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="13" height="13"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Backup &amp; Restore
        </a>
    </div>
    <a href="/" class="btn btn--ghost mgmt-nav__back">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12"><polyline points="15 18 9 12 15 6"/></svg>
        Werkruimte
    </a>
</nav>
